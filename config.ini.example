[sip]
; SIP server hostname or IP address (required)
server = pbx.example.com

; SIP server port (optional, default: 5060)
port = 5060

; SIP account username (required)
username = echo-test

; SIP account password (required)
password = changeme

; Display name shown to callers (optional, default: username)
display_name = Echo Server

; Transport protocol: udp, tcp, or tls (optional, default: udp)
transport = udp

; Local SIP port (optional, default: 5060)
; Using a fixed port prevents stale contact registrations on the PBX
; when the server restarts
local_port = 5060

[bridge]
; SIP extension to dial when a GSM call arrives (optional, default: 599)
sip_destination = 599

; Timeout in seconds for the outbound SIP call (optional, default: 30, range: 5-120)
sip_dial_timeout_sec = 30

[sms]
; Enable SMS monitoring and forwarding (optional, default: true)
enabled = true

; Discord webhook URL for SMS notifications (optional, leave empty to disable forwarding)
; discord_webhook_url = https://discord.com/api/webhooks/123456789/abcdef

; Path to SQLite database for SMS persistence (optional)
db_path = /var/lib/gsm-sip-bridge/data.db

; SIM phone number shown in Discord notifications (optional)
; Used as fallback when AT+CNUM does not return the number from the SIM
; phone_number = +1234567890
